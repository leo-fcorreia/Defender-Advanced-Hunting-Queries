// 1. Manual list (optional, kept for compatibility)
let MaliciousExtensionList = datatable(TargetExtensionID: string) [
    'BrowserExtensionID1', 
    'BrowserExtensionID2'
];
// 2. Imports the new CSV mapping the ID and Name
let MaliciousBrowserExtensions = externaldata(['Extension ID']: string, ['Extension Name']: string)
[@'https://raw.githubusercontent.com/leo-fcorreia/threat-hunting/refs/heads/main/Suspicious-Browser-Extensions.csv'] 
with (format='csv', ignoreFirstRecord=True);
// 3. Search and correlation
DeviceFileEvents
| where Timestamp > ago(30d)
| where FolderPath has_any (@'\AppData\Local')
| where FolderPath has 'Extensions'
// Extracts the 32‑character ID from the path
| extend DetectedID = extract(@'\\Extensions\\([a-p]{32})', 1, FolderPath)
// Filters if the ID is in the manual list or in the CSV
| where DetectedID in~ (MaliciousExtensionList) or DetectedID in~ (MaliciousBrowserExtensions)
// Fetches the extension name from the CSV based on the detected ID
| lookup kind=leftouter MaliciousBrowserExtensions on $left.DetectedID == $right.['Extension ID']
| summarize 
    FirstDetected = min(Timestamp), 
    LastDetected = max(Timestamp), 
    DeviceCount = dcount(DeviceName),
    SamplePath = any(FolderPath),
    ExtensionName = any(['Extension Name']) // Captures the name if available
    by DetectedID, DeviceName, InitiatingProcessAccountName
| project FirstDetected, LastDetected, DeviceName, DetectedID, ExtensionName = iff(isempty(ExtensionName), 'Unknown Extension Name', ExtensionName), InitiatingProcessAccountName, SamplePath
| order by LastDetected desc
